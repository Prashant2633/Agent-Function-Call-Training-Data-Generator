# ============================================================
# Agent Function-Call Training Data Generator — Environment
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── API Keys ─────────────────────────────────────────────
# Groq API key — get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key — get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Model Selection ─────────────────────────────────────────────
# Generator A (Groq): "llama-3.3-70b-versatile" (best, tool-call support) or "llama-3.1-8b-instant" (fastest)
GENERATOR_MODEL_GROQ=llama-3.3-70b-versatile

# Generator B (Gemini): "gemini-2.0-flash" (fast) or "gemini-1.5-pro" (best)
GENERATOR_MODEL_GEMINI=gemini-2.0-flash

# Scorer/Judge model (Gemini used as evaluator)
SCORER_MODEL=gemini-2.0-flash

# Embedding model for semantic validation + dedup
EMBEDDING_MODEL=models/text-embedding-004

# ── Database ──────────────────────────────────────────────────
# PostgreSQL (via docker-compose)
DATABASE_URL = postgresql://neondb_owner:npg_z9KHoDrcOCT3@ep-floral-leaf-atjrcqr5.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Generation Settings ───────────────────────────────────────
# Temperature for diverse generation (Type 1, 2, 4)
GENERATION_TEMPERATURE=0.7

# Temperature for edge case generation (Type 3 ambiguous)
EDGE_CASE_TEMPERATURE=0.2

# Temperature for scoring/judge (should be low for consistency)
SCORING_TEMPERATURE=0.1

# ── Validation Thresholds ─────────────────────────────────────
# Minimum cosine similarity between instruction embedding and tool description
# Below this → LOW_SEMANTIC_SIMILARITY failure
EMBEDDING_SIMILARITY_THRESHOLD=0.75

# Minimum cosine similarity between two instructions before rejecting as duplicate
DEDUP_SIMILARITY_THRESHOLD=0.95

# ── Quality Thresholds ────────────────────────────────────────
# Composite score thresholds
HIGH_QUALITY_THRESHOLD=0.85
MEDIUM_QUALITY_THRESHOLD=0.65

# Minimum score_delta to create a preference pair (avoids trivial pairs)
MIN_PREFERENCE_DELTA=0.05

# ── Pipeline Settings ─────────────────────────────────────────
# Default number of worker threads
DEFAULT_WORKERS=4

# Max API retries on failure (uses exponential backoff)
MAX_RETRIES=3

# Paraphrase variations per seed instruction
PARAPHRASE_COUNT=10

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
