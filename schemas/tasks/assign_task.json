{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "assign_task",
  "domain": "tasks",
  "description": "Assigns or delegates a task to a user.",
  "parameters": {
    "type": "object",
    "properties": {
      "task_id": {
        "type": "string",
        "description": "Unique identifier of target task.",
        "examples": [
          "task_998877"
        ]
      },
      "assignee_id": {
        "type": "string",
        "description": "Unique identifier of assignee user.",
        "examples": [
          "usr_887766"
        ]
      },
      "notify": {
        "type": "boolean",
        "description": "Whether to send an notification email/alert to assignee.",
        "default": true,
        "examples": [
          true,
          false
        ]
      },
      "message": {
        "type": "string",
        "description": "Optional custom delegation note sent to assignee.",
        "examples": [
          "Hey, assigning this bug to you as you wrote the login code."
        ]
      },
      "due_date": {
        "type": "string",
        "description": "Optional new or modified due date YYYY-MM-DD.",
        "examples": [
          "2024-09-30"
        ]
      }
    },
    "required": [
      "task_id",
      "assignee_id"
    ]
  }
}